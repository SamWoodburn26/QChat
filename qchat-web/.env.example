# Frontend (safe to expose in browser)
VITE_SERVER_URL=http://localhost:7071
VITE_MICROSOFT_CLIENT_ID=your-microsoft-client-id
VITE_MICROSOFT_TENANT_ID=your-microsoft-tenant-id
VITE_MICROSOFT_REDIRECT_URI=https://localhost/microsoft-callback.html
VITE_MICROSOFT_OBJECT_ID=optional-object-id-not-used-by-frontend
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend (server-only; keep real values in `.env`, not in `local.settings.json`)
MONGODB_URI=your-mongodb-connection-string
OLLAMA_URL=http://127.0.0.1:11434
SERVER_URL=http://localhost:7071
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_TENANT_ID=your-microsoft-tenant-id
MICROSOFT_OBJECT_ID=optional-object-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_CLIENT_SECRET_ID=optional-secret-id
MICROSOFT_SENDER_UPN=sender@example.com
# Set MAIL_PROVIDER to `google` after you fill in the Google sender settings below.
# Supported values: `microsoft`, `google`
MAIL_PROVIDER=microsoft
GOOGLE_EMAIL_SENDER=your-gmail-address@gmail.com
GOOGLE_APP_PASSWORD=your-16-char-google-app-password
GOOGLE_SMTP_HOST=smtp.gmail.com
GOOGLE_SMTP_PORT=587
OLLAMA_MODEL=mistral-small3.2:latest
QCHAT_URLS_PATH=qu_docs.txt
DB_NAME=chatbot_db
QCHAT_DEBUG_RETRIEVAL=true
